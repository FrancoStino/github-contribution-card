{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn vercel-build",
  "outputDirectory": ".",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
